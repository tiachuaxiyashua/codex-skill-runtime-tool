# Codex Skill Runtime environment for this project only.
# This is the single runtime env entry point.
# Keep the real API key in config/codex_api_key.txt, not in this file.

SKILL_RUNTIME_TARGET_WORKSPACE=${SKILL_RUNTIME_WORKSPACE_ROOT}
# Legacy root is retained for older commands. Skill discovery should prefer SKILL_RUNTIME_SKILL_REPOS.
SKILL_RUNTIME_ROOT=${SKILL_RUNTIME_TARGET_WORKSPACE}
SKILL_RUNTIME_CODEX_HOME=${SKILL_RUNTIME_TOOL_ROOT}\.skill-runtime\codex-home
SKILL_RUNTIME_STATE_ROOT=${SKILL_RUNTIME_TOOL_ROOT}\.skill-runtime\state
SKILL_RUNTIME_CODEX_EXECUTABLE=codex
SKILL_RUNTIME_SKILL_REPOS=${SKILL_RUNTIME_WORKSPACE_ROOT}\game_studio_source_code\Claude-Code-Game-Studios;${SKILL_RUNTIME_WORKSPACE_ROOT}\art_pipeline_skill;${SKILL_RUNTIME_WORKSPACE_ROOT}\audio_pipeline_skill;${SKILL_RUNTIME_WORKSPACE_ROOT}\godot_tool_bridge_skill
SKILL_RUNTIME_ADD_DIRS=
SKILL_RUNTIME_NAMESPACES=ccgs=${SKILL_RUNTIME_WORKSPACE_ROOT}\game_studio_source_code\Claude-Code-Game-Studios;art=${SKILL_RUNTIME_WORKSPACE_ROOT}\art_pipeline_skill;audio=${SKILL_RUNTIME_WORKSPACE_ROOT}\audio_pipeline_skill;godot=${SKILL_RUNTIME_WORKSPACE_ROOT}\godot_tool_bridge_skill

# Optional external tool paths. Keep paths relative to this workspace when possible.
SKILL_RUNTIME_GODOT=${SKILL_RUNTIME_WORKSPACE_ROOT}\..\GAME\Godot_v4.5.1\Godot_v4.6.1-stable_win64_console.exe

# Environment variables injected into the runtime parent process.
# MCP servers can read these directly.
# 2D art pipeline: Stability Matrix Forge/A1111-compatible backend with --api.
SKILL_RUNTIME_ENV_FORGE_BASE_URL=http://127.0.0.1:7860

# Audio pipeline: Stability Matrix ComfyUI backend.
SKILL_RUNTIME_ENV_COMFYUI_BASE_URL=http://127.0.0.1:8188
# SKILL_RUNTIME_ENV_COMFYUI_ROOT=${COMFYUI_ROOT}
# SKILL_RUNTIME_ENV_GODOT_EXE=${GODOT_EXE}
SKILL_RUNTIME_ENV_HF_ENDPOINT=https://hf-mirror.com
SKILL_RUNTIME_CAPABILITY_FORGE_ENDPOINT=http://127.0.0.1:7860
SKILL_RUNTIME_CAPABILITY_FORGE_KIND=image-generation-api
SKILL_RUNTIME_CAPABILITY_FORGE_STATUS=configured
SKILL_RUNTIME_CAPABILITY_FORGE_DESCRIPTION=Stability Matrix Forge or A1111-compatible backend exposed with --api.
SKILL_RUNTIME_CAPABILITY_COMFYUI_ENDPOINT=http://127.0.0.1:8188
SKILL_RUNTIME_CAPABILITY_COMFYUI_KIND=node-graph-generation-api
SKILL_RUNTIME_CAPABILITY_COMFYUI_STATUS=configured
SKILL_RUNTIME_CAPABILITY_COMFYUI_DESCRIPTION=Stability Matrix ComfyUI backend for image, animation, or audio workflows when corresponding skills use it.

SKILL_RUNTIME_MODEL=gpt-5.4
SKILL_RUNTIME_STRICT_TOOLS=true
SKILL_RUNTIME_STRICT_SCHEMA=false
SKILL_RUNTIME_QA=auto
SKILL_RUNTIME_QA_AUTO_PATTERNS=prototype:*engine*;prototype:*godot*;vertical-slice:*;dev-story:*
SKILL_RUNTIME_ASSUME_YES=true
SKILL_RUNTIME_DRY_RUN=false
SKILL_RUNTIME_MAX_STEPS=8

CODEX_PROVIDER=OpenAI
CODEX_BASE_URL=https://api.psydo.top
CODEX_WIRE_API=responses
CODEX_REQUIRES_OPENAI_AUTH=true
CODEX_API_KEY_FILE=${SKILL_RUNTIME_TOOL_ROOT}\config\codex_api_key.txt

CODEX_CONFIG=["review_model=\"gpt-5.4\"","model_reasoning_effort=\"xhigh\"","disable_response_storage=true","network_access=\"enabled\"","windows_wsl_setup_acknowledged=true","model_context_window=1000000","model_auto_compact_token_limit=900000"]
