# Codex Skill Runtime environment for this project only.
# This is the single runtime env entry point.
# Keep the real API key in config/codex_api_key.txt, not in this file.

SKILL_RUNTIME_TARGET_WORKSPACE=${SKILL_RUNTIME_WORKSPACE_ROOT}
# Legacy root is retained for older commands. Skill discovery should prefer SKILL_RUNTIME_SKILL_REPOS.
SKILL_RUNTIME_ROOT=${SKILL_RUNTIME_TARGET_WORKSPACE}
SKILL_RUNTIME_CODEX_HOME=${SKILL_RUNTIME_TOOL_ROOT}/.skill-runtime/codex-home
SKILL_RUNTIME_STATE_ROOT=${SKILL_RUNTIME_TOOL_ROOT}/.skill-runtime/state
SKILL_RUNTIME_CODEX_EXECUTABLE=codex
SKILL_RUNTIME_SKILL_REPOS=${SKILL_RUNTIME_WORKSPACE_ROOT}/game_studio_source_code/Claude-Code-Game-Studios||${SKILL_RUNTIME_WORKSPACE_ROOT}/art_pipeline_skill||${SKILL_RUNTIME_WORKSPACE_ROOT}/audio_pipeline_skill||${SKILL_RUNTIME_WORKSPACE_ROOT}/godot_tool_bridge_skill
SKILL_RUNTIME_ADD_DIRS=
CODEX_SKILL_RUNTIME_BARE=true
SKILL_RUNTIME_NAMESPACES=ccgs=${SKILL_RUNTIME_WORKSPACE_ROOT}/game_studio_source_code/Claude-Code-Game-Studios;art=${SKILL_RUNTIME_WORKSPACE_ROOT}/art_pipeline_skill;audio=${SKILL_RUNTIME_WORKSPACE_ROOT}/audio_pipeline_skill;godot=${SKILL_RUNTIME_WORKSPACE_ROOT}/godot_tool_bridge_skill

# Optional external tool paths. Keep paths relative to this workspace when possible.
SKILL_RUNTIME_ENV_GODOT_EXE=/Applications/Godot.app/Contents/MacOS/Godot

# Environment variables injected into the runtime parent process.
# MCP servers can read these directly.
# 2D art pipeline: Stability Matrix Forge/A1111-compatible backend with --api.
SKILL_RUNTIME_ENV_FORGE_BASE_URL=http://127.0.0.1:7861

# Audio pipeline: Stability Matrix ComfyUI backend.
SKILL_RUNTIME_ENV_COMFYUI_BASE_URL=http://127.0.0.1:8188
# Stability Matrix local data root on this Mac.
SKILL_RUNTIME_ENV_STABILITY_MATRIX_ROOT=/Applications/Data
SKILL_RUNTIME_ENV_COMFYUI_ROOT=/Applications/Data/Packages/ComfyUI
SKILL_RUNTIME_ENV_NATIVE_DEPS_ROOT=${SKILL_RUNTIME_TOOL_ROOT}/.skill-runtime/native-deps
SKILL_RUNTIME_PLUGIN_PYTHON_PATH=${SKILL_RUNTIME_TOOL_ROOT}/.skill-runtime/skill-python/bin
# SKILL_RUNTIME_ENV_GODOT_EXE=${GODOT_EXE}
SKILL_RUNTIME_ENV_HF_ENDPOINT=https://hf-mirror.com
CODEX_PROVIDER=OpenAI
CODEX_BASE_URL=https://api.psydo.top
CODEX_WIRE_API=responses
CODEX_REQUIRES_OPENAI_AUTH=true
CODEX_API_KEY_FILE=${SKILL_RUNTIME_TOOL_ROOT}/config/codex_api_key.txt
SKILL_RUNTIME_SERVICES_JSON={"services":[{"id":"forge","label":"Forge / A1111","kind":"image-generation-api","endpoint":"http://127.0.0.1:7861","health_url":"http://127.0.0.1:7861/sdapi/v1/options","description":"Stability Matrix Forge or A1111-compatible backend exposed in API-only mode for A1111 /sdapi routes.","start_cmd":"cd \"${SKILL_RUNTIME_ENV_STABILITY_MATRIX_ROOT}/Packages/Stable Diffusion WebUI reForge\" && PATH=\"${SKILL_RUNTIME_PLUGIN_PYTHON_PATH}:${SKILL_RUNTIME_ENV_NATIVE_DEPS_ROOT}/bin:/opt/homebrew/bin:${HOME}/.local/bin:${PATH}\" PKG_CONFIG_PATH=\"${SKILL_RUNTIME_ENV_NATIVE_DEPS_ROOT}/lib/pkgconfig:/opt/homebrew/lib/pkgconfig:/opt/homebrew/share/pkgconfig:${PKG_CONFIG_PATH:-}\" NO_PROXY=\"${NO_PROXY:-127.0.0.1,localhost,::1}\" no_proxy=\"${no_proxy:-127.0.0.1,localhost,::1}\" PIP_INDEX_URL=\"${PIP_INDEX_URL:-https://pypi.tuna.tsinghua.edu.cn/simple}\" PIP_TRUSTED_HOST=\"${PIP_TRUSTED_HOST:-pypi.tuna.tsinghua.edu.cn}\" UV_INDEX_URL=\"${UV_INDEX_URL:-https://pypi.tuna.tsinghua.edu.cn/simple}\" ./venv/bin/python -u launch.py --api --nowebui --skip-python-version-check --skip-torch-cuda-test"},{"id":"comfyui","label":"ComfyUI","kind":"node-graph-generation-api","endpoint":"http://127.0.0.1:8188","health_url":"http://127.0.0.1:8188/system_stats","description":"Stability Matrix ComfyUI backend for image, animation, or audio workflows when corresponding skills use it.","start_cmd":"cd \"${SKILL_RUNTIME_ENV_STABILITY_MATRIX_ROOT}/Packages/ComfyUI\" && PATH=\"${SKILL_RUNTIME_PLUGIN_PYTHON_PATH}:${SKILL_RUNTIME_ENV_NATIVE_DEPS_ROOT}/bin:/opt/homebrew/bin:${HOME}/.local/bin:${PATH}\" NO_PROXY=\"${NO_PROXY:-127.0.0.1,localhost,::1}\" no_proxy=\"${no_proxy:-127.0.0.1,localhost,::1}\" PIP_INDEX_URL=\"${PIP_INDEX_URL:-https://pypi.tuna.tsinghua.edu.cn/simple}\" PIP_TRUSTED_HOST=\"${PIP_TRUSTED_HOST:-pypi.tuna.tsinghua.edu.cn}\" UV_INDEX_URL=\"${UV_INDEX_URL:-https://pypi.tuna.tsinghua.edu.cn/simple}\" ./venv/bin/python -u main.py --port 8188 --preview-method none --cpu --disable-xformers --dont-print-server"}]}

SKILL_RUNTIME_MODEL=gpt-5.4
SKILL_RUNTIME_STRICT_TOOLS=true
SKILL_RUNTIME_STRICT_SCHEMA=true
SKILL_RUNTIME_QA=auto
SKILL_RUNTIME_QA_AUTO_PATTERNS=prototype:*engine*;prototype:*godot*;vertical-slice:*;dev-story:*
SKILL_RUNTIME_ASSUME_YES=true
SKILL_RUNTIME_DRY_RUN=false
SKILL_RUNTIME_MAX_STEPS=20
SKILL_RUNTIME_CONTEXT_MODE=lean
SKILL_RUNTIME_LEAN_SKILL_BODY_CHARS=8000
SKILL_RUNTIME_LEAN_SECTION_MAX_CHARS=1200
SKILL_RUNTIME_LEAN_AGENT_BODY_CHARS=5000
SKILL_RUNTIME_MEMORY_SIDE_QUERY=auto
SKILL_RUNTIME_MEMORY_JOBS=background
SKILL_RUNTIME_CODEX_TIMEOUT_SECONDS=900
SKILL_RUNTIME_CODEX_STALL_TIMEOUT_SECONDS=180
SKILL_RUNTIME_CODEX_RETRY_ATTEMPTS=3
SKILL_RUNTIME_CODEX_RETRY_BACKOFF_SECONDS=3
SKILL_RUNTIME_CODEX_SCHEMA_STALL_TIMEOUT_SECONDS=45
SKILL_RUNTIME_CODEX_SCHEMA_RETRY_ATTEMPTS=1
SKILL_RUNTIME_CODEX_SCHEMA_RETRY_BACKOFF_SECONDS=0

SKILL_RUNTIME_CODEX_OSS=false
# SKILL_RUNTIME_CODEX_LOCAL_PROVIDER=ollama

# Cloud/API mode can be re-enabled by overriding these values in a local env file or CLI flags.
# CODEX_PROVIDER=OpenAI
# CODEX_BASE_URL=https://api.psydo.top
# CODEX_WIRE_API=responses
# CODEX_REQUIRES_OPENAI_AUTH=true
# CODEX_API_KEY_FILE=${SKILL_RUNTIME_TOOL_ROOT}/config/codex_api_key.txt

CODEX_CONFIG=["review_model=\"gpt-5.4\"","model_reasoning_effort=\"low\"","disable_response_storage=true","network_access=\"enabled\"","windows_wsl_setup_acknowledged=true","model_context_window=32768","model_auto_compact_token_limit=28000"]
