{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Skill Runtime Action Response",
  "type": "object",
  "required": ["status", "summary", "actions", "final"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["action_required", "final", "blocked"]
    },
    "summary": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "reason", "parameters"],
        "properties": {
          "tool": {
            "type": "string",
            "anyOf": [
              {
                "enum": [
              "read_file",
              "Read",
              "glob",
              "Glob",
              "grep",
              "Grep",
              "write_file",
              "Write",
              "edit_file",
              "Edit",
              "multi_edit",
              "MultiEdit",
              "bash",
              "Bash",
              "powershell",
              "PowerShell",
              "terminal_capture",
              "TerminalCapture",
              "repl",
              "REPL",
              "sleep",
              "Sleep",
              "task",
              "Task",
              "agent",
              "Agent",
              "task_create",
              "TaskCreate",
              "task_get",
              "TaskGet",
              "task_list",
              "TaskList",
              "task_output",
              "TaskOutput",
              "task_update",
              "TaskUpdate",
              "ask_user_question",
              "AskUserQuestion",
              "todo_write",
              "TodoWrite",
              "skill",
              "Skill",
              "discover_skills",
              "DiscoverSkills",
              "tool_search",
              "ToolSearch",
              "plan_mode",
              "PlanMode",
              "enter_plan_mode",
              "exit_plan_mode",
              "verify_plan_execution",
              "EnterPlanMode",
              "ExitPlanMode",
              "VerifyPlanExecution",
              "config",
              "Config",
              "project_memory_read",
              "ProjectMemoryRead",
              "project_memory_write",
              "ProjectMemoryWrite",
              "asset_register",
              "AssetRegister",
              "notebook_edit",
              "NotebookEdit",
              "snip",
              "Snip",
              "send_user_file",
              "SendUserFile",
              "review_artifact",
              "ReviewArtifact",
              "brief",
              "Brief",
              "SendUserMessage",
              "remote_trigger",
              "RemoteTrigger",
              "structured_output",
              "StructuredOutput",
              "workflow",
              "Workflow",
              "team_create",
              "TeamCreate",
              "team_delete",
              "TeamDelete",
              "enter_worktree",
              "EnterWorktree",
              "exit_worktree",
              "ExitWorktree",
              "cron_create",
              "CronCreate",
              "cron_list",
              "CronList",
              "cron_delete",
              "CronDelete",
              "monitor",
              "Monitor",
              "lsp",
              "LSP",
              "send_message",
              "SendMessage",
              "task_stop",
              "TaskStop",
              "memory_read",
              "MemoryRead",
              "memory_write",
              "MemoryWrite",
              "bridge",
              "Bridge",
              "voice",
              "Voice",
              "ide",
              "IDE",
              "web_fetch",
              "WebFetch",
              "web_search",
              "WebSearch",
              "web_browser",
              "WebBrowser",
              "list_mcp_resources",
              "ListMcpResources",
              "ListMcpResourcesTool",
              "read_mcp_resource",
              "ReadMcpResource",
              "ReadMcpResourceTool",
              "mcp_elicitation",
              "McpElicitation",
              "mcp",
              "MCP",
              "mcp_auth",
              "McpAuth",
              "McpAuthTool"
                ]
              },
              {
                "pattern": "^mcp__[A-Za-z0-9_.:-]+__[A-Za-z0-9_.:-]+$"
              }
            ]
          },
          "reason": {
            "type": "string"
          },
          "parameters": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "final": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
