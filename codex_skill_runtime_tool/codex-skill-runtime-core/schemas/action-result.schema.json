{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Codex Skill Runtime Action Response",
  "type": "object",
  "required": ["status", "summary", "actions", "final"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["action_required", "final", "blocked"]
    },
    "summary": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "reason", "parameters"],
        "properties": {
          "tool": {
            "type": "string",
            "enum": [
              "read_file",
              "Read",
              "glob",
              "Glob",
              "grep",
              "Grep",
              "write_file",
              "Write",
              "edit_file",
              "Edit",
              "multi_edit",
              "MultiEdit",
              "bash",
              "Bash",
              "powershell",
              "PowerShell",
              "terminal_capture",
              "TerminalCapture",
              "repl",
              "REPL",
              "task",
              "Task",
              "agent",
              "Agent",
              "task_create",
              "TaskCreate",
              "task_get",
              "TaskGet",
              "task_list",
              "TaskList",
              "task_output",
              "TaskOutput",
              "task_update",
              "TaskUpdate",
              "ask_user_question",
              "AskUserQuestion",
              "todo_write",
              "TodoWrite",
              "skill",
              "Skill",
              "tool_search",
              "ToolSearch",
              "plan_mode",
              "PlanMode",
              "EnterPlanMode",
              "ExitPlanMode",
              "VerifyPlanExecution",
              "project_memory_read",
              "ProjectMemoryRead",
              "project_memory_write",
              "ProjectMemoryWrite",
              "asset_register",
              "AssetRegister",
              "send_message",
              "SendMessage",
              "task_stop",
              "TaskStop",
              "memory_read",
              "MemoryRead",
              "memory_write",
              "MemoryWrite",
              "bridge",
              "Bridge",
              "voice",
              "Voice",
              "ide",
              "IDE",
              "web_fetch",
              "WebFetch",
              "web_search",
              "WebSearch",
              "web_browser",
              "WebBrowser",
              "list_mcp_resources",
              "ListMcpResources",
              "read_mcp_resource",
              "ReadMcpResource",
              "mcp_elicitation",
              "McpElicitation",
              "mcp",
              "MCP"
            ]
          },
          "reason": {
            "type": "string"
          },
          "parameters": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    },
    "final": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
